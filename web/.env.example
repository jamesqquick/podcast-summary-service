# Copy to .env and fill in values for local dev.
# These are SERVER-SIDE only — never exposed to the browser.

# URL of the Dropcast API Worker (no trailing slash).
# Run the API worker locally: cd .. && pnpm dev  →  http://localhost:8787
API_URL=http://localhost:8787

# Bearer token for the API Worker (matches API_TOKEN set on the Worker).
# Check the Worker's .dev.vars for the value to use here.
API_TOKEN=your-dev-token-here

# Cloudflare Turnstile site key — public, safe to expose.
# Leave empty to skip Turnstile during local dev.
PUBLIC_TURNSTILE_SITE_KEY=
