{
  "name": "podcast-summary-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "description": "A headless Cloudflare Workers service that turns a list of links into an entertaining AI-generated audio podcast summary.",
  "scripts": {
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "wrangler types && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "agents": "latest",
    "@modelcontextprotocol/sdk": "latest",
    "hono": "^4.12.26",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  }
}
